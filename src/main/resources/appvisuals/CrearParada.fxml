<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="anchorPane" minHeight="0.0" minWidth="0.0" prefHeight="400.0" prefWidth="400.0" styleClass="windowBG" stylesheets="@Estilo.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rutas.redtransporte.controllers.CrearParadaController">
   <children>
      <Pane layoutX="55.0" layoutY="51.0" prefHeight="296.0" prefWidth="290.0" styleClass="windowPane">
         <children>
            <Label layoutX="95.0" layoutY="23.0" text="Parada">
               <font>
                  <Font name="SansSerif Bold" size="30.0" />
               </font>
            </Label>
            <Label layoutX="32.0" layoutY="96.0" text="Nombre:">
               <font>
                  <Font name="SansSerif Bold" size="18.0" />
               </font>
            </Label>
            <TextField fx:id="txtNombre" layoutX="120.0" layoutY="96.0" prefHeight="25.0" prefWidth="144.0" styleClass="windowField" />
            <Label layoutX="32.0" layoutY="166.0" text="Tipo:">
               <font>
                  <Font name="SansSerif Bold" size="18.0" />
               </font>
            </Label>
            <ComboBox fx:id="cbxTipo" layoutX="120.0" layoutY="166.0" prefWidth="144.0" promptText="Seleccionar" styleClass="windowButton" />
            <Button fx:id="btnAceptar" layoutX="58.0" layoutY="245.0" mnemonicParsing="false" onAction="#guardarParada" prefWidth="75.0" styleClass="windowButton" text="Aceptar">
               <font>
                  <Font name="SansSerif Bold" size="12.0" />
               </font></Button>
            <Button fx:id="btnCancelar" layoutX="155.0" layoutY="245.0" mnemonicParsing="false" onAction="#volver" prefWidth="75.0" styleClass="windowButton" text="Cancelar">
               <font>
                  <Font name="SansSerif Bold" size="12.0" />
               </font>
            </Button>
            <Button fx:id="btnEliminar" layoutX="26.0" layoutY="245.0" mnemonicParsing="false" prefWidth="75.0" styleClass="windowButton" text="Eliminar" visible="false">
               <font>
                  <Font name="SansSerif Bold" size="12.0" />
               </font>
            </Button>
         </children>
      </Pane>
   </children>
</AnchorPane>
